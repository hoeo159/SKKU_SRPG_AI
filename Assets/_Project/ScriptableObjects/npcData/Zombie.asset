    \uC9E7\uB2E4.\n\uD50C\uB808\uC774\uC5B4\uC5D0\uAC8C \uACF5\uACA9\uC801\uC774\uC9C0\uB9CC
    \uB300\uD654\uB97C \uD560 \uC218 \uC788\uAC70\uB098 \uCE58\uB8CC\uB97C \uC694\uCCAD\uD560
    \uC218 \uC788\uB2E4.\n\uCE58\uB8CC \uBC29\uBC95\uC744 \uC5BB\uC73C\uBA74 \uC6B0\uD638\uB3C4\uAC00
    \uC99D\uAC00\uD560 \uC218 \uC788\uB2E4."
  personaConstraint: "1~2\uBB38\uC7A5\uC73C\uB85C\uB9CC \uB2F5\uD574\uB77C.\n\uC704\uD611/\uD611\uBC15\uC740
